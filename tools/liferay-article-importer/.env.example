LIFERAY_BASE_URL=http://localhost:8080
LIFERAY_SITE_ID=34371
LIFERAY_OAUTH_CLIENT_ID=
LIFERAY_OAUTH_CLIENT_SECRET=

# One fixed locale per importer instance for this release.
LIFERAY_DEFAULT_LOCALE=en-US
LIFERAY_CONTENT_VIEWABLE_BY=Anyone

# Exactly one fixed image source for this importer instance.
LIFERAY_IMAGE_SOURCE_TYPE=assetLibrary
LIFERAY_IMAGE_SOURCE_ID=45123
# Optional: restrict image resolution to one Documents and Media folder.
LIFERAY_IMAGE_SOURCE_FOLDER_ID=45678

MAX_IMPORT_ROWS=5000
MAX_UPLOAD_MB=50
MAX_ACTIVE_SESSIONS=10
IMAGE_INDEX_PAGE_SIZE=200
PREVIEW_ROWS=20
BATCH_POLL_INTERVAL_MS=1500
BATCH_POLL_TIMEOUT_MS=600000
LIFERAY_REQUEST_TIMEOUT_MS=30000
LIFERAY_MAX_RETRIES=3
LIFERAY_RETRY_BASE_DELAY_MS=500
SESSION_TTL_MS=1800000

# Keep the migration UI local unless LAN access is explicitly required.
HOST=127.0.0.1
PORT=4174
