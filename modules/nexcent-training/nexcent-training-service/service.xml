<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.4.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_4_0.dtd">

<service-builder
    dependency-injector="ds"
    package-path="com.nexcent.training"
    short-no-such-exception-enabled="false"
>
    <author>Nexcent Training</author>
    <namespace>NXC</namespace>

    <entity
        local-service="true"
        name="ImportJob"
        remote-service="false"
        uuid="true"
    >
        <column name="importJobId" primary="true" type="long" />

        <column name="groupId" type="long" />

        <column name="companyId" type="long" />
        <column name="userId" type="long" />
        <column name="userName" type="String" />
        <column name="createDate" type="Date" />
        <column name="modifiedDate" type="Date" />

        <column name="jobKey" type="String" />
        <column name="fileName" type="String" />
        <column name="status" type="String" />
        <column name="totalRows" type="int" />
        <column name="successRows" type="int" />
        <column name="failedRows" type="int" />
        <column name="errorMessage" type="String" />

        <order by="desc">
            <order-column name="createDate" />
        </order>

        <finder name="G" return-type="Collection">
            <finder-column name="groupId" />
        </finder>
        <finder name="JK_G" return-type="ImportJob" unique="true">
            <finder-column name="jobKey" />
            <finder-column name="groupId" />
        </finder>
    </entity>
</service-builder>
